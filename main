# --- 状態管理用 ---

var current_quiz_idx = 0


@onready var dialog_label = %DialogLabel
@onready var heart_bar = %HeartBar
var love_point = 50



func next_quiz():
	character.play("default") # 表示時は「通常」アニメ	
	# 次のリスト位置へ
	current_list_pos += 1
	
	# 全ての問題を使い切ったら、再度シャッフルして最初に戻る
	if current_list_pos >= quiz_indices.size():
		current_list_pos = 0
		quiz_indices.shuffle()
		print("全ての問題を解きました。シャッフルしてループします。")
	
	# 現在のランダムな位置にあるクイズのインデックスを取得
	current_quiz_idx = quiz_indices[current_list_pos]
	
	display_quiz()

# display_quiz 内で使うデータも、この current_quiz_idx に基づいて取得

func game_clear():
	dialog_label.text = "2分間あっと言う間だったね！また話そう？"
	# クリア演出
