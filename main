extends Control

# --- 設定値 ---
const TARGET_TIME = 120.0
const MESSAGE_DISPLAY_TIME = 4.0
# ボタンを配列で保持（インスペクターで紐付けるか、%UniqueNameで取得）
@onready var buttons = [%ButtonA, %ButtonB, %ButtonC, %ButtonD]
@onready var character: AnimatedSprite2D = %Character # もしAnimatedSprite2Dなら


# インデックスを管理するための配列
var quiz_indices = []
var current_list_pos = 0
func display_quiz():
	var data = quiz_data[current_quiz_idx]
	dialog_label.text = data["text"]
	for i in range(buttons.size()):
		buttons[i].text = data["options"][i]
	
	character.play("default") # 表示時は「通常」アニメ	
func _ready():
	# ボタン接続
	for i in range(buttons.size()):
		buttons[i].pressed.connect(_on_button_pressed.bind(i))
	
	# バー初期化
	heart_bar.max_value = TARGET_TIME
	heart_bar.value = 0
	
	# ランダム化の準備
	randomize()
	for i in range(quiz_data.size()):
		quiz_indices.append(i)
	quiz_indices.shuffle() # リストをシャッフル
	
	current_quiz_idx = quiz_indices[current_list_pos]
	display_quiz()



# ABCDのいずれかが押された時に呼ばれる共通関数
func _on_button_pressed(button_index: int):

	var data = quiz_data[current_quiz_idx]

	if button_index == data["correct"]:
		heart_bar.value += data["point"] 
		dialog_label.text = data["success_msg"] 
		character.play("happy") # 正解アニメ
		
		var tween = create_tween()
		tween.tween_property(character, "position:y", character.position.y - 20, 0.1)
		tween.tween_property(character, "position:y", character.position.y, 0.1)
	else:
		heart_bar.value -= 10
		dialog_label.text = data["fail_msg"] 
		character.play("sad") # 不正解アニメ
		
		var tween = create_tween()
		tween.tween_property(character, "position:x", character.position.x + 10, 0.05)
		tween.tween_property(character, "position:x", character.position.x - 10, 0.05)
		tween.tween_property(character, "position:x", character.position.x, 0.05)

	if heart_bar.value >= heart_bar.max_value:
		game_clear()
	else:
		await get_tree().create_timer(MESSAGE_DISPLAY_TIME).timeout
		next_quiz()
	
	# --- クイズデータ (19問) ---
